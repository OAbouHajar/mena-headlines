# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your own values.
# NEVER commit the .env file — it is already in .gitignore.
# ──────────────────────────────────────────────────────────────

# ── Firebase (client-side, required) ─────────────────────────
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# ── Azure OpenAI (server-side, required for /api/intelligence) ──
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# ── Azure Blob Storage (server-side, required for intel caching) ──
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# ── ACLED conflict data (server-side, optional) ─────────────
# Register free at https://developer.acleddata.com
ACLED_EMAIL=your@email.com
ACLED_PASSWORD=your-acled-password

# ── OpenSky Network (server-side, optional — for flight data) ──
# Register free at https://opensky-network.org
OPENSKY_USERNAME=your-opensky-username
OPENSKY_CLIENT_ID=your-client-id
OPENSKY_CLIENT_SECRET=your-client-secret
OPENSKY_PASSWORD=your-opensky-password

# ── Azure Application Insights (optional — telemetry) ───────
VITE_APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
